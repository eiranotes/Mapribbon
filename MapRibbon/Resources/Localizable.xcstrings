{
  "sourceLanguage": "ko",
  "strings": {
    "보드": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ボード"
          }
        }
      }
    },
    "아틀라스": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アトラス"
          }
        }
      }
    },
    "설정": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定"
          }
        }
      }
    },
    "새 보드 만들기": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいボードを作る"
          }
        }
      }
    },
    "날짜 선택": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日付を選択"
          }
        }
      }
    },
    "미리보기": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレビュー"
          }
        }
      }
    },
    "저장 및 공유": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存・共有"
          }
        }
      }
    },
    "장소와 사진 수정": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "場所と写真を編集"
          }
        }
      }
    },
    "찍어둔 사진이,\n하루의 여행 보드가 됩니다.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "撮った写真が、\n1日の旅ボードになります。"
          }
        }
      }
    },
    "내 사진으로 만들어보기": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分の写真で作ってみる"
          }
        }
      }
    },
    "사진 접근 계속": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真へのアクセスを続ける"
          }
        }
      }
    },
    "영구 잠금 해제": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "永久アンロック"
          }
        }
      }
    },
    "아틀라스 보기": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アトラスを見る"
          }
        }
      }
    },
    "board.saved": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진 보관함에 저장했습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真ライブラリに保存しました。"
          }
        }
      }
    },
    "board.photo_count": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d장"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%d枚"
          }
        }
      }
    },
    "board.atlas_progress": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ %d번째 기록 · %d/%d 지역"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の%d件目 · %d/%d地域"
          }
        }
      }
    },
    "board.atlas_progress_new": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 첫 기록 · %d/%d 지역"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の初記録 · %d/%d地域"
          }
        }
      }
    },
    "board.season.spring": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진으로 다시 엮은 봄의 하루"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真で綴り直す春の一日"
          }
        }
      }
    },
    "board.season.summer": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진으로 다시 엮은 여름의 하루"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真で綴り直す夏の一日"
          }
        }
      }
    },
    "board.season.autumn": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진으로 다시 엮은 가을의 하루"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真で綴り直す秋の一日"
          }
        }
      }
    },
    "board.season.winter": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진으로 다시 엮은 겨울의 하루"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真で綴り直す冬の一日"
          }
        }
      }
    }
  },
  "version": "1.0"
}
