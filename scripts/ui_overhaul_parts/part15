          }

          capture --screenshot-onboarding onboarding
          capture --screenshot-home home
          capture --screenshot-library library
          capture --screenshot-atlas atlas
          capture --screenshot-settings settings
          capture --screenshot-paywall paywall
          capture --screenshot-generation generation
          capture --screenshot-export export
          capture --screenshot-places places
          capture --screenshot-board-editor board-editor
          capture --screenshot-board-canvas board-canvas

          {
            echo "device=${{ steps.simulator.outputs.name }}"
            echo "runtime=${{ steps.simulator.outputs.runtime }}"
            echo "bundle_id=$BUNDLE_ID"
            echo "commit=$GITHUB_SHA"
          } > "$OUT/metadata.txt"
          ls -lh "$OUT"

      - name: Upload UI screenshots
        if: steps.xcode.outputs.status == '0'
        uses: actions/upload-artifact@v4
        with:
          name: mapribbon-ui-overhaul-screenshots
          path: ${{ runner.temp }}/mapribbon-ui-overhaul
          retention-days: 14
          if-no-files-found: error

      - name: Upload Xcode result bundle
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: mapribbon-xcresult
          path: |
            ${{ runner.temp }}/MapRibbon.xcresult
            ${{ runner.temp }}/xcodebuild.log
          retention-days: 7
          if-no-files-found: warn

      - name: Fail when Xcode tests fail
        if: steps.xcode.outputs.status != '0'
        run: exit 1
''',
)
