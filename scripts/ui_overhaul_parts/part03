                let y = CGFloat((index * 73) % 107) / 107 * size.height
                let radius = CGFloat(1 + index % 3)
                context.fill(Path(ellipseIn: CGRect(x: x, y: y, width: radius, height: radius)), with: .color(.black.opacity(0.08)))
            }
        }
    }
